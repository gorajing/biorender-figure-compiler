# Extraction mode controls which adapter src/core/extract.ts dispatches to.
# Default (no env vars set): fixture mode. Demo works with no configuration.
# Set both vars below to enable live extraction via the Anthropic API.

EXTRACT_MODE=api
ANTHROPIC_API_KEY=

# Optional tuning (defaults are sensible; override only if you need to)
# EXTRACT_API_MODEL=claude-sonnet-4-6
# EXTRACT_API_TIMEOUT_MS=90000
# EXTRACT_API_MAX_CANDIDATES=1
